public func processPoint(point: Point) -> Point {
    let pointBytes = boltffiEncode { writer in point.encode(to: &writer) }
    return pointBytes.withUnsafeBufferPointer { pointBuf in
        let buf = boltffi_process_point(pointBuf.baseAddress, UInt(pointBuf.count))
        defer { boltffi_free_buf(buf) }
        return boltffiDecodeOwnedBuf(buf.ptr, Int(buf.len)) { reader in Point.decode(from: &reader) }
    }
}
