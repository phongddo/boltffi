---
source: riff_bindgen/src/render/swift/templates.rs
expression: "render_function(&func, \"riff\")"
---
public func uploadFile(path: String, to destination: String) async throws -> String {
    let futureHandle = path.withCString { pathPtr in destination.withCString { destinationPtr in riff_upload_file_start(UnsafeRawPointer(pathPtr).assumingMemoryBound(to: UInt8.self), UInt(path.utf8.count), UnsafeRawPointer(destinationPtr).assumingMemoryBound(to: UInt8.self), UInt(destination.utf8.count)) } }

    return try await riffAsyncCall(
        futureHandle: futureHandle,
        pollFn: riff_upload_file_poll,
        completeFn: riff_upload_file_complete,
        cancelFn: riff_upload_file_cancel,
        freeFn: riff_upload_file_free
    ) { buf, status in
        guard status.code == 0 else { riff_free_buf_u8(buf); throw FfiError(message: "ffi call failed") }
        defer { riff_free_buf_u8(buf) }
        return riffDecodeOwnedBuf(buf.ptr, Int(buf.len)) { reader in reader.readString() }
    }
}
