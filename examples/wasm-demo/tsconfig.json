{
  "compilerOptions": {
    "target": "ES2021",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2021", "DOM"],
    "declaration": true,
    "outDir": "./dist",
    "rootDir": "./generated/typescript",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true
  },
  "include": ["generated/typescript/*.ts"]
}
